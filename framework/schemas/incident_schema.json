{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QALIS Incident Record",
  "description": "Schema for a quality incident detected by QALIS monitoring",
  "type": "object",
  "required": ["incident_id","system_id","detected_at","category","severity","qalis_metric_triggered"],
  "properties": {
    "incident_id":                  { "type": "string" },
    "system_id":                    { "type": "string" },
    "detected_at":                  { "type": "string", "format": "date-time" },
    "resolved_at":                  { "type": "string", "format": "date-time" },
    "category":                     { "type": "string" },
    "severity":                     { "type": "string", "enum": ["low","medium","high","critical"] },
    "description":                  { "type": "string" },
    "root_cause":                   { "type": "string" },
    "resolution":                   { "type": "string" },
    "mttr_hours":                   { "type": "number" },
    "qalis_detection_lag_hours":    { "type": "number" },
    "baseline_detection_lag_hours": { "type": "number" },
    "detection_improvement_pct":    { "type": "number" },
    "qalis_metric_triggered":       { "type": "string" },
    "affected_users_estimated":     { "type": "integer" },
    "post_mortem_completed":        { "type": "boolean" },
    "preventable_by_qalis":         { "type": "boolean" }
  }
}
